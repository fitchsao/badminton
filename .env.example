# ============ Lark 应用凭证 ============
# 从 Lark 开发者后台获取:
#   飞书(中国):     https://open.feishu.cn/app
#   Lark(国际):     https://open.larksuite.com/app
LARK_APP_ID=cli_xxxxxxxxxxxx
LARK_APP_SECRET=替换为你的_App_Secret

# Lark 域名:
#   - 飞书(中国大陆): https://open.feishu.cn
#   - Lark(国际版):   https://open.larksuite.com
LARK_BASE_URL=https://open.larksuite.com

# 机器人发消息的目标群 chat_id
# 获取方法见 README.md 的「找到群 chat_id」章节
LARK_TARGET_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxx

# ============ 应用配置 ============
# 报名页面公网可访问的地址(供机器人卡片里的按钮跳转)
# 必须是 HTTPS,且要在 Lark 后台「重定向 URL」白名单中
APP_BASE_URL=https://badminton.example.com

# 服务端口
PORT=3000

# 时区(影响定时任务和时间显示)
TZ=Asia/Shanghai

# ============ 数据库 ============
DATABASE_URL=postgres://badminton:badminton_pwd@db:5432/badminton

# ============ 安全密钥 ============
# Cookie HMAC 签名密钥,用于防伪造登录态
# 生成方式: openssl rand -hex 32
COOKIE_HMAC_SECRET=替换为_openssl_rand_hex_32_的输出

# 管理员触发报名机器人的 token (在 /admin/trigger-signup 用)
# 生成方式: openssl rand -hex 24
ADMIN_TRIGGER_TOKEN=替换为_openssl_rand_hex_24_的输出

# ============ 开发后门(生产环境必须置空) ============
# 启用 /api/dev/* 调试端点的密钥
# 生产环境必须设为空字符串 "" 关闭这些端点
DEV_SECRET=

# ============ 业务参数 ============
# 每场最大正式名额数(超过自动进候补)
MAX_SLOTS=16

# 活动相关时间(24 小时制,数字)
# 周一 10:30 开放报名 -> 周二 18:00 截止 -> 周二 20:00-22:00 活动
SIGNUP_OPEN_DOW=1
SIGNUP_OPEN_HOUR=10
SIGNUP_OPEN_MINUTE=30

EVENT_DOW=2
EVENT_START_HOUR=20
EVENT_END_HOUR=22

# 活动开始前几小时截止报名
SIGNUP_CLOSE_HOURS_BEFORE_EVENT=2
